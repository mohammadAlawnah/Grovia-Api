<div style="font-family: Arial, sans-serif; background-color: #f4f6f8; padding: 30px;">
  <div style="max-width: 600px; margin: auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 5px 20px rgba(0,0,0,0.1);">
    
    <!-- Header -->
    <div style="background: linear-gradient(135deg, #4CAF50, #2e7d32); padding: 20px; text-align: center;">
      <h1 style="color: #ffffff; margin: 0;">Grovia</h1>
    </div>

    <!-- Body -->
    <div style="padding: 30px; text-align: center;">
      
      <h2 style="color: #333; margin-bottom: 10px;">
        Hello <span style="color: #4CAF50;"><%= email %></span>
      </h2>

      <p style="color: #666; font-size: 16px; margin-bottom: 20px;">
        You successfully logged into your account.
      </p>

      <!-- Info Box -->
      <div style="background: #f1f8e9; padding: 15px; border-radius: 8px; margin-bottom: 25px;">
        <p style="margin: 5px 0; color: #333;">
          📅 <strong>Date:</strong> <%= today.toDateString() %>
        </p>
        <p style="margin: 5px 0; color: #333;">
          ⏰ <strong>Time:</strong> <%= today.toLocaleTimeString() %>
        </p>
      </div>

      <!-- Button -->
      <a href="#" style="
        display: inline-block;
        padding: 12px 25px;
        background-color: #4CAF50;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
      ">
        View Account
      </a>

    </div>

    <!-- Footer -->
    <div style="background-color: #f4f6f8; padding: 15px; text-align: center; font-size: 13px; color: #999;">
      © 2026 Grovia. All rights reserved.
    </div>

  </div>
</div>