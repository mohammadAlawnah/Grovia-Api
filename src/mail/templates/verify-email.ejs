<div style="margin:0; padding:0; background-color:#eef2f7; font-family:Arial, sans-serif;">
  <div style="max-width:600px; margin:40px auto; background:#ffffff; border-radius:16px; overflow:hidden; box-shadow:0 10px 40px rgba(0,0,0,0.15);">
    
    <!-- Top Gradient -->
    <div style="background: linear-gradient(135deg, #00c853, #2e7d32); padding:30px; text-align:center;">
      <h1 style="color:#ffffff; margin:0; font-size:28px; letter-spacing:1px;">
        Grovia
      </h1>
      <p style="color:#e8f5e9; margin-top:8px; font-size:14px;">
        Healthy Life Starts Here
      </p>
    </div>

    <!-- Body -->
    <div style="padding:40px 30px; text-align:center;">
      
      <h2 style="color:#222; margin-bottom:10px; font-size:24px;">
        Verify Your Email Address
      </h2>

      <p style="color:#666; font-size:16px; line-height:1.6; margin-bottom:25px;">
        You're almost there. Just one final step to activate your account.
      </p>

      <!-- Highlight Box -->
      <div style="background:#f1f8e9; border-left:5px solid #4CAF50; padding:15px; border-radius:8px; margin-bottom:30px;">
        <p style="margin:0; color:#333; font-size:14px;">
          Click the button below to confirm your email and start your journey.
        </p>
      </div>

      <!-- Button -->
      <a href="<%= link %>" style="
        display:inline-block;
        padding:14px 35px;
        background: linear-gradient(135deg, #00c853, #2e7d32);
        color:#ffffff;
        text-decoration:none;
        border-radius:10px;
        font-size:16px;
        font-weight:bold;
        box-shadow:0 6px 20px rgba(0,200,83,0.4);
      ">
        ✔ Verify My Account
      </a>

      <!-- Divider -->
      <div style="margin:35px 0; height:1px; background:#eee;"></div>

      <!-- Small Text -->
      <p style="color:#999; font-size:13px; line-height:1.6;">
        If you didn’t create this account, you can safely ignore this email.
      </p>

    </div>

    <!-- Footer -->
    <div style="background:#f9fafb; padding:20px; text-align:center;">
      <p style="margin:0; font-size:12px; color:#aaa;">
        © 2026 Grovia — All Rights Reserved
      </p>
    </div>

  </div>
</div>