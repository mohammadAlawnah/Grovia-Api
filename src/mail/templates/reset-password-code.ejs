<div style="margin:0; padding:0; background-color:#eef2f7; font-family:Arial, sans-serif;">
  <div style="max-width:600px; margin:40px auto; background:#ffffff; border-radius:16px; overflow:hidden; box-shadow:0 10px 40px rgba(0,0,0,0.15);">
    
    <!-- Header -->
    <div style="background: linear-gradient(135deg, #2962ff, #0039cb); padding:30px; text-align:center;">
      <h1 style="color:#ffffff; margin:0; font-size:28px;">
        Grovia
      </h1>
      <p style="color:#c5cae9; margin-top:8px; font-size:14px;">
        Secure Verification
      </p>
    </div>

    <!-- Body -->
    <div style="padding:40px 30px; text-align:center;">
      
      <h2 style="color:#222; font-size:24px; margin-bottom:10px;">
        Reset Password Code
      </h2>

      <p style="color:#666; font-size:16px; line-height:1.6; margin-bottom:25px;">
        Use the following verification code to reset your password.
      </p>

      <!-- Code Box -->
      <div style="
        display:inline-block;
        padding:20px 35px;
        background:#f3f6ff;
        border-radius:12px;
        border:1px dashed #2962ff;
        margin-bottom:25px;
      ">
        <span style="
          font-size:32px;
          letter-spacing:6px;
          font-weight:bold;
          color:#0039cb;
        ">
          <%= code %>
        </span>
      </div>

      <!-- Warning -->
      <p style="color:#999; font-size:13px; line-height:1.6;">
        ⏳ This code will expire in a few minutes.
      </p>

      <!-- Divider -->
      <div style="margin:30px 0; height:1px; background:#eee;"></div>

      <!-- Security Note -->
      <p style="color:#999; font-size:13px;">
        Do not share this code with anyone.
      </p>

    </div>

    <!-- Footer -->
    <div style="background:#f9fafb; padding:20px; text-align:center;">
      <p style="margin:0; font-size:12px; color:#aaa;">
        © 2026 Grovia — All Rights Reserved
      </p>
    </div>

  </div>
</div>