<div style="margin:0; padding:0; background-color:#eef2f7; font-family:Arial, sans-serif;">
  <div style="max-width:600px; margin:40px auto; background:#ffffff; border-radius:16px; overflow:hidden; box-shadow:0 10px 40px rgba(0,0,0,0.15);">
    
    <!-- Header -->
    <div style="background: linear-gradient(135deg, #ff6f00, #e65100); padding:30px; text-align:center;">
      <h1 style="color:#ffffff; margin:0; font-size:28px;">
        Grovia
      </h1>
      <p style="color:#ffe0b2; margin-top:8px; font-size:14px;">
        Secure Your Account
      </p>
    </div>

    <!-- Body -->
    <div style="padding:40px 30px; text-align:center;">
      
      <h2 style="color:#222; font-size:24px; margin-bottom:10px;">
        Reset Your Password
      </h2>

      <p style="color:#666; font-size:16px; line-height:1.6; margin-bottom:25px;">
        We received a request to reset your password.  
        Click the button below to choose a new one.
      </p>

      <!-- Warning Box -->
      <div style="background:#fff3e0; border-left:5px solid #ff9800; padding:15px; border-radius:8px; margin-bottom:30px;">
        <p style="margin:0; color:#333; font-size:14px;">
          ⚠ This link will expire soon for your security.
        </p>
      </div>

      <!-- Button -->
      <a href="<%= resetPasswordLink %>" style="
        display:inline-block;
        padding:14px 35px;
        background: linear-gradient(135deg, #ff6f00, #e65100);
        color:#ffffff;
        text-decoration:none;
        border-radius:10px;
        font-size:16px;
        font-weight:bold;
        box-shadow:0 6px 20px rgba(255,111,0,0.4);
      ">
        🔒 Reset My Password
      </a>

      <!-- Divider -->
      <div style="margin:35px 0; height:1px; background:#eee;"></div>

      <!-- Fallback -->
      <p style="color:#999; font-size:13px; line-height:1.6;">
        If the button doesn’t work, copy and paste this link into your browser:
      </p>

      <p style="word-break:break-all; color:#ff6f00; font-size:13px;">
        <%= resetPasswordLink %>
      </p>

      <!-- Note -->
      <p style="margin-top:20px; color:#999; font-size:13px;">
        If you didn’t request a password reset, you can safely ignore this email.
      </p>

    </div>

    <!-- Footer -->
    <div style="background:#f9fafb; padding:20px; text-align:center;">
      <p style="margin:0; font-size:12px; color:#aaa;">
        © 2026 Grovia — All Rights Reserved
      </p>
    </div>

  </div>
</div>